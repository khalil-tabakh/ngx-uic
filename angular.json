{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "cli": {
        "analytics": false,
        "packageManager": "npm"
    },
    "newProjectRoot": "projects",
    "projects": {
        "ngx-uic": {
            "projectType": "library",
            "root": "projects/ngx-uic",
            "sourceRoot": "projects/ngx-uic/src",
            "prefix": "ngx",
            "architect": {
                "build": {
                    "builder": "@angular/build:ng-packagr",
                    "options": {
                        "project": "projects/ngx-uic/ng-package.json"
                    },
                    "configurations": {
                        "production": {
                            "tsConfig": "projects/ngx-uic/tsconfig.lib.prod.json"
                        },
                        "development": {
                            "tsConfig": "projects/ngx-uic/tsconfig.lib.json"
                        }
                    },
                    "defaultConfiguration": "production"
                }
            }
        },
        "player": {
            "projectType": "library",
            "root": "projects/ngx-uic/player",
            "sourceRoot": "projects/ngx-uic/player/src",
            "prefix": "ngx",
            "architect": {
                "test": {
                    "builder": "@angular/build:karma",
                    "options": {
                        "tsConfig": "projects/ngx-uic/player/tsconfig.spec.json",
                        "polyfills": [],
                        "codeCoverage": true
                    }
                }
            }
        },
        "range": {
            "projectType": "library",
            "root": "projects/ngx-uic/range",
            "sourceRoot": "projects/ngx-uic/range/src",
            "prefix": "ngx",
            "architect": {
                "test": {
                    "builder": "@angular/build:karma",
                    "options": {
                        "tsConfig": "projects/ngx-uic/range/tsconfig.spec.json",
                        "polyfills": [],
                        "codeCoverage": true
                    }
                }
            }
        },
        "scroller": {
            "projectType": "library",
            "root": "projects/ngx-uic/scroller",
            "sourceRoot": "projects/ngx-uic/scroller/src",
            "prefix": "ngx",
            "architect": {
                "test": {
                    "builder": "@angular/build:karma",
                    "options": {
                        "tsConfig": "projects/ngx-uic/scroller/tsconfig.spec.json",
                        "polyfills": [],
                        "codeCoverage": true
                    }
                }
            }
        }
    }
}